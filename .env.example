# AgentDash local development and packaging defaults.
# Copy this file to `.env` for local builds, or set the same variables in CI.

# Desktop installer default cloud server origin.
# This value drives the packaged dashboard API origin and is also packed into
# `agentdash-desktop-defaults.json` to pre-fill the Local Runtime Server URL.
AGENTDASH_DEFAULT_CLOUD_ORIGIN=https://agentdash.example.com

# Desktop release builds default to external mode, meaning the app connects to
# the configured cloud server. Builtin is an explicit opt-in local API host.
AGENTDASH_DESKTOP_DEFAULT_API_MODE=external

# Optional Rust build cache for desktop packaging.
# SCCACHE_DIR=.agentdash/sccache
