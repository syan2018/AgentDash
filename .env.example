# AgentDash local development and packaging defaults.
# Copy this file to `.env` for local builds, or set the same variables in CI.

# Desktop installer default cloud server origin.
# This value is packed into `agentdash-desktop-defaults.json` and pre-fills
# the Local Runtime Server URL in the Windows desktop app.
AGENTDASH_DEFAULT_CLOUD_ORIGIN=https://agentdash.example.com

# Desktop API is the loopback-only API used by the desktop shell.
# Release builds intentionally keep this fixed at http://127.0.0.1:17301.
AGENTDASH_DESKTOP_DEFAULT_API_MODE=builtin
AGENTDASH_DESKTOP_DEFAULT_API_ORIGIN=http://127.0.0.1:17301

# Optional Rust build cache for desktop packaging.
# SCCACHE_DIR=.agentdash/sccache
