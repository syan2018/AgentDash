# Default: normalize text files and store/check out as LF.
* text=auto eol=lf

# Windows shell scripts should use CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Keep common binary assets untouched.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.db binary
*.db-shm binary
*.db-wal binary
