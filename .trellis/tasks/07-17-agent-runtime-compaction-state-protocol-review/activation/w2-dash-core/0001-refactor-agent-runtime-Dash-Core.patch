+    pub context: &'a AgentContext,
+}
+
+// ─── Tool Approval Types ───────────────────────────────────
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+#[serde(rename_all = "snake_case")]
+pub struct ToolApprovalRequest {
