-fn is_apply_patch_file_op_or_end(line: &str) -> bool {
-    line == "*** End Patch"
-        || line.starts_with("*** Add File: ")
-        || line.starts_with("*** Delete File: ")
-        || line.starts_with("*** Update File: ")
-}
