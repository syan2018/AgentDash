      "name": "nested_object_array_required_stable_order",
      "schema": {
        "type": "object",
        "required": ["config"],
        "properties": {
          "items": {"type":"array","items":{"type":"object","required":["id"],"properties":{"note":{"type":"string"},"id":{"type":"integer"}}}},
          "config": {"type":"object","required":["enabled"],"properties":{"mode":{"type":"string"},"enabled":{"type":"boolean","description":"first line\nignored line"}}}
        }
      },
      "expected": [
        "- `config` (required, object)",
        "- `config.enabled` (required, boolean): first line",
        "- `config.mode` (optional, string)",
        "- `items` (optional, array<object>)",
        "- `items[].id` (required, integer)",
        "- `items[].note` (optional, string)"
      ]
    },
    {
