{
  "key": "filesystem",
  "preset_key": "filesystem",
  "display_name": "Filesystem",
  "description": "使用 @modelcontextprotocol/server-filesystem 通过 stdio 暴露本机文件系统读写能力，默认作用域在工作目录。",
