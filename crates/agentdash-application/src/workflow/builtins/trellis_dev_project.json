{
  "key": "trellis_dev_project",
  "name": "Trellis Dev Lifecycle / Project",
  "description": "Project 层面的上下文整理与记录沉淀生命周期。",
  "target_kind": "project",
  "recommended_roles": ["project"],
  "workflows": [
    {
      "key": "trellis_dev_project_start",
      "name": "Trellis Project / Start",
      "description": "整理项目级上下文、Agent 配置和共享容器。",
      "contract": {
        "injection": {
          "instructions": [
            "当前处于 Project Start workflow，优先建立项目级基线上下文。",
            "关注默认 Agent、共享上下文和挂载策略是否可被后续 Story/Task 消费。"
          ],
          "context_bindings": [
            {
              "kind": "runtime_context",
              "locator": "project_session_context",
              "reason": "项目级会话上下文",
              "required": true,
              "title": "Project Session Context"
            }
          ]
        },
        "completion": {
          "default_artifact_type": "phase_note",
          "default_artifact_title": "项目上下文记录"
        }
      }
    },
    {
      "key": "trellis_dev_project_record",
      "name": "Trellis Project / Record",
      "description": "输出项目级总结与共享规范沉淀。",
      "contract": {
        "injection": {
          "instructions": [
            "当前处于 Project Record workflow，重点沉淀可被多个 Story/Task 复用的项目级规则。"
          ],
          "context_bindings": [
            {
              "kind": "journal_target",
              "locator": "workspace_journal",
              "reason": "共享记录沉淀位置",
              "required": false,
              "title": "Workspace Journal"
            }
          ]
        },
        "completion": {
          "default_artifact_type": "session_summary",
          "default_artifact_title": "项目总结"
        }
      }
    }
  ],
  "lifecycle": {
    "key": "trellis_dev_project",
    "name": "Trellis Dev Lifecycle / Project",
    "description": "Project 生命周期编排：Start -> Record。",
    "entry_step_key": "start",
    "steps": [
      {
        "key": "start",
        "title": "Start",
        "description": "建立项目级上下文。",
        "primary_workflow_key": "trellis_dev_project_start",
        "session_binding": "not_required",
        "transition": {
          "policy": {
            "kind": "manual",
            "next_step_key": "record"
          }
        }
      },
      {
        "key": "record",
        "title": "Record",
        "description": "输出项目总结。",
        "primary_workflow_key": "trellis_dev_project_record",
        "session_binding": "not_required",
        "transition": {
          "policy": {
            "kind": "manual"
          }
        }
      }
    ]
  }
}
