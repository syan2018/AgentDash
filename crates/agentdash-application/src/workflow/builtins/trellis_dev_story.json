{
  "key": "trellis_dev_story",
  "name": "Trellis Dev Lifecycle / Story",
  "description": "Story 层面的上下文整理、执行对齐与记录沉淀生命周期。",
  "binding_kind": "story",
  "recommended_binding_roles": ["story"],
  "workflows": [
    {
      "key": "trellis_dev_story_start",
      "name": "Trellis Story / Start",
      "description": "整理 Story PRD、约束与上下文。",
      "contract": {
        "injection": {
          "instructions": [
            "当前处于 Story Start workflow，优先整理 PRD、背景和执行边界。",
            "如果 Story 缺少关键规范，应先补全上下文再继续拆解。"
          ],
          "context_bindings": [
            {
              "locator": "context://story_context_snapshot",
              "reason": "Story 上下文快照",
              "required": true,
              "title": "Story Context Snapshot"
            },
            {
              "locator": "context://story_prd",
              "reason": "Story PRD",
              "required": false,
              "title": "Story PRD"
            }
          ]
        },
        "completion": {
          "default_artifact_type": "phase_note",
          "default_artifact_title": "Story 开始记录"
        }
      }
    },
    {
      "key": "trellis_dev_story_align",
      "name": "Trellis Story / Align",
      "description": "对齐 Story 的执行状态与拆解结果。",
      "contract": {
        "injection": {
          "instructions": [
            "当前处于 Story Align workflow，重点检查 Story 的目标、任务拆解和资源准备是否一致。"
          ],
          "context_bindings": [
            {
              "locator": "context://story_review_checklist",
              "reason": "Story 对齐检查清单",
              "required": true,
              "title": "Story Review Checklist"
            }
          ]
        },
        "completion": {
          "checks": [
            {
              "key": "story_alignment_evidence",
              "kind": "artifact_exists",
              "description": "需要至少一份 Story 对齐记录",
              "payload": {
                "artifact_type": "phase_note"
              }
            }
          ],
          "default_artifact_type": "phase_note",
          "default_artifact_title": "Story 对齐记录"
        }
      }
    },
    {
      "key": "trellis_dev_story_record",
      "name": "Trellis Story / Record",
      "description": "沉淀 Story 级记录与交接说明。",
      "contract": {
        "injection": {
          "instructions": [
            "当前处于 Story Record workflow，重点沉淀结构化总结和后续建议。"
          ],
          "context_bindings": [
            {
              "locator": "context://workspace_journal",
              "reason": "工作区日志",
              "required": false,
              "title": "Workspace Journal"
            }
          ]
        },
        "completion": {
          "default_artifact_type": "session_summary",
          "default_artifact_title": "Story 总结"
        }
      }
    }
  ],
  "lifecycle": {
    "key": "trellis_dev_story",
    "name": "Trellis Dev Lifecycle / Story",
    "description": "Story 生命周期编排：Start -> Align -> Record。",
    "entry_step_key": "start",
    "steps": [
      {
        "key": "start",
        "description": "准备 Story 执行上下文。",
        "workflow_key": "trellis_dev_story_start"
      },
      {
        "key": "align",
        "description": "验证 Story 对齐状态。",
        "workflow_key": "trellis_dev_story_align"
      },
      {
        "key": "record",
        "description": "输出 Story 记录。",
        "workflow_key": "trellis_dev_story_record"
      }
    ]
  }
}
