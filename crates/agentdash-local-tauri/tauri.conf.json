{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentDash",
  "version": "0.1.0",
  "identifier": "com.agentdash.desktop",
  "build": {
    "beforeBuildCommand": "pnpm --dir ../.. --filter app-tauri build",
    "devUrl": "http://127.0.0.1:5381",
    "frontendDist": "../../packages/app-tauri/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AgentDash",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "targets": "all"
  }
}
