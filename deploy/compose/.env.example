AGENTDASH_VERSION=0.1.0
AGENTDASH_IMAGE_REPOSITORY=agentdash-cloud
AGENTDASH_PUBLIC_ORIGIN=http://127.0.0.1:8080
AGENTDASH_BIND_HOST=0.0.0.0
AGENTDASH_PORT=3001
AGENTDASH_RELAY_WS_URL=ws://127.0.0.1:8080/ws/backend
AGENTDASH_SECRET_KEY=change-me
AGENTDASH_ENCRYPTION_KEY=change-me
AGENTDASH_MIN_DESKTOP_VERSION=0.1.0
AGENTDASH_RECOMMENDED_DESKTOP_VERSION=0.1.0
AGENTDASH_RELAY_PROTOCOL_VERSION=1
RUST_LOG=info

POSTGRES_DB=agentdash
POSTGRES_USER=agentdash
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://agentdash:change-me@postgres:5432/agentdash

# Managed PostgreSQL deployments should set DATABASE_URL to the external
# PostgreSQL endpoint and use docker-compose.managed-postgres.yml as an
# additional compose file.
# DATABASE_URL=postgresql://agentdash:<password>@managed-postgres.example.internal:5432/agentdash
