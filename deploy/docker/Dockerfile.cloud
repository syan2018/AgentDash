FROM node:24-bookworm AS web-builder
WORKDIR /src

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY assets ./assets
COPY packages ./packages
COPY scripts ./scripts

RUN pnpm install --frozen-lockfile
RUN pnpm run frontend:build

FROM rust:bookworm AS server-builder
WORKDIR /src

RUN apt-get update \
    && apt-get install -y --no-install-recommends cmake pkg-config perl \
    && rm -rf /var/lib/apt/lists/*

COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
RUN rustup toolchain install nightly --profile minimal && rustup default nightly

COPY crates ./crates

ARG AGENTDASH_GIT_SHA=unknown
ARG AGENTDASH_BUILD_TIME=unknown
ENV AGENTDASH_GIT_SHA=${AGENTDASH_GIT_SHA}
ENV AGENTDASH_BUILD_TIME=${AGENTDASH_BUILD_TIME}

RUN cargo build --release --bin agentdash-server

FROM debian:bookworm-slim AS runtime
WORKDIR /app

ARG AGENTDASH_VERSION=unknown
ARG AGENTDASH_GIT_SHA=unknown
ARG AGENTDASH_BUILD_TIME=unknown

LABEL org.opencontainers.image.title="AgentDash Cloud" \
    org.opencontainers.image.version="${AGENTDASH_VERSION}" \
    org.opencontainers.image.revision="${AGENTDASH_GIT_SHA}" \
    org.opencontainers.image.created="${AGENTDASH_BUILD_TIME}"

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates wget \
    && rm -rf /var/lib/apt/lists/*

COPY --from=server-builder /src/target/release/agentdash-server /usr/local/bin/agentdash-server
COPY --from=web-builder /src/packages/app-web/dist /app/web

ENV AGENTDASH_BIND_HOST=0.0.0.0
ENV AGENTDASH_PORT=3001
ENV AGENTDASH_WEB_DIST_DIR=/app/web

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD wget -qO- http://127.0.0.1:3001/api/health >/dev/null || exit 1

ENTRYPOINT ["agentdash-server"]
CMD ["serve"]
