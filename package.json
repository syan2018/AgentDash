{
  "name": "agentdash",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AgentDashboard — 统一看板系统，管理多设备、多项目中 AI Agent 的协同工作",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm run dev:joint",
    "dev:mono": "node ./scripts/dev-joint.js --skip-local",
    "dev:mono:skip-build": "node ./scripts/dev-joint.js --skip-local --skip-build",
    "dev:joint": "node ./scripts/dev-joint.js",
    "dev:joint:skip-build": "node ./scripts/dev-joint.js --skip-build",
    "dev:server": "cargo run --bin agentdash-server",
    "dev:local": "node ./scripts/dev-joint.js --skip-server --skip-frontend",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:frontend-wait": "node scripts/wait-for-ready.js 3001 /api/health 120 && pnpm --filter frontend dev",
    "dev:backend": "pnpm run kill:backend && cargo run --bin agentdash-server",
    "frontend:dev": "pnpm --filter frontend dev",
    "frontend:build": "pnpm --filter frontend build",
    "frontend:check": "pnpm --filter frontend exec tsc --noEmit",
    "frontend:test": "pnpm --filter frontend test",
    "e2e:test": "playwright test",
    "e2e:test:critical": "playwright test tests/e2e/story-context-injection.spec.ts tests/e2e/task-drawer-return.spec.ts",
    "e2e:debug": "playwright test --headed --debug",
    "backend:dev": "cargo run --bin agentdash-server",
    "backend:build": "cargo build --release",
    "backend:check": "cargo check",
    "backend:test": "cargo test --workspace",
    "check": "pnpm run backend:check && pnpm run backend:test && pnpm run frontend:check && pnpm run frontend:test && pnpm run e2e:test:critical",
    "clean": "cargo clean && rimraf frontend/dist",
    "kill-ports": "node scripts/kill-ports.js",
    "kill:frontend": "node scripts/kill-ports.js 5380 5381 5382",
    "kill:backend": "node scripts/kill-ports.js 3001"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  }
}
