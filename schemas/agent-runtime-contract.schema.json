{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ManagedRuntimeContractSchema",
  "type": "object",
  "properties": {
    "command": {
      "$ref": "#/$defs/ManagedRuntimeCommandEnvelope"
    },
    "operation_receipt": {
      "$ref": "#/$defs/ManagedRuntimeOperationReceipt"
    },
    "read": {
      "$ref": "#/$defs/ManagedRuntimeReadRequest"
    },
    "changes": {
      "$ref": "#/$defs/ManagedRuntimeChangesRequest"
    },
    "error": {
      "$ref": "#/$defs/ManagedRuntimeGatewayError"
    },
    "snapshot": {
      "$ref": "#/$defs/ManagedRuntimeSnapshot"
    },
    "change_page": {
      "$ref": "#/$defs/ManagedRuntimeChangePage"
    }
  },
  "required": [
    "command",
    "operation_receipt",
    "read",
    "changes",
    "error",
    "snapshot",
    "change_page"
  ],
  "$defs": {
    "ManagedRuntimeCommandEnvelope": {
      "type": "object",
      "properties": {
        "operation_id": {
          "type": "string"
        },
        "idempotency_key": {
          "type": "string"
        },
        "thread_id": {
          "type": "string"
        },
        "expected_revision": {
          "anyOf": [
            {
              "$ref": "#/$defs/RuntimeProjectionRevision"
            },
            {
              "type": "null"
            }
          ]
        },
        "command": {
          "$ref": "#/$defs/ManagedRuntimeCommand"
        }
      },
      "required": [
        "operation_id",
        "idempotency_key",
        "thread_id",
        "command"
      ]
    },
    "RuntimeProjectionRevision": {
      "$ref": "#/$defs/RuntimeU64"
    },
    "RuntimeU64": {
      "description": "canonical unsigned-decimal Runtime coordinate",
      "type": "string",
      "pattern": "^(0|[1-9][0-9]{0,19})$",
      "maxLength": 20
    },
    "ManagedRuntimeCommand": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "initial_context": {
              "anyOf": [
                {
                  "$ref": "#/$defs/ManagedRuntimeInitialContextPackage"
                },
                {
                  "type": "null"
                }
              ]
            },
            "kind": {
              "type": "string",
              "const": "create"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "resume"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "activate"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "content": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/ManagedRuntimeContentBlock"
              }
            },
            "kind": {
              "type": "string",
              "const": "submit_input"
            }
          },
          "required": [
            "kind",
            "content"
          ]
        },
        {
          "type": "object",
          "properties": {
            "expected_turn_id": {
              "type": "string"
            },
            "content": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/ManagedRuntimeContentBlock"
              }
            },
            "kind": {
              "type": "string",
              "const": "steer"
            }
          },
          "required": [
            "kind",
            "expected_turn_id",
            "content"
          ]
        },
        {
          "type": "object",
          "properties": {
            "expected_turn_id": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "interrupt"
            }
          },
          "required": [
            "kind",
            "expected_turn_id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "request_compaction"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "interaction_id": {
              "type": "string"
            },
            "response": {
              "$ref": "#/$defs/ManagedRuntimeInteractionResponse"
            },
            "kind": {
              "type": "string",
              "const": "resolve_interaction"
            }
          },
          "required": [
            "kind",
            "interaction_id",
            "response"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "close"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "child_thread_id": {
              "type": "string"
            },
            "through_completed_turn_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "kind": {
              "type": "string",
              "const": "fork"
            }
          },
          "required": [
            "kind",
            "child_thread_id"
          ]
        }
      ]
    },
    "ManagedRuntimeInitialContextPackage": {
      "type": "object",
      "properties": {
        "package_id": {
          "type": "string"
        },
        "schema_version": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "mode": {
          "$ref": "#/$defs/ManagedRuntimeInitialContextMode"
        },
        "contributions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ManagedRuntimeInitialContextContribution"
          }
        },
        "digest": {
          "type": "string"
        }
      },
      "required": [
        "package_id",
        "schema_version",
        "mode",
        "contributions",
        "digest"
      ]
    },
    "ManagedRuntimeInitialContextMode": {
      "type": "string",
      "enum": [
        "compact",
        "workflow_only",
        "constraints_only"
      ]
    },
    "ManagedRuntimeInitialContextContribution": {
      "type": "object",
      "properties": {
        "contribution_id": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "content": {
          "$ref": "#/$defs/ManagedRuntimeInitialContextContributionContent"
        }
      },
      "required": [
        "contribution_id",
        "digest",
        "content"
      ]
    },
    "ManagedRuntimeInitialContextContributionContent": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "summary": {
              "type": "string"
            },
            "provenance": {
              "$ref": "#/$defs/ManagedRuntimeContextProvenance"
            },
            "kind": {
              "type": "string",
              "const": "compact_summary"
            }
          },
          "required": [
            "kind",
            "summary",
            "provenance"
          ]
        },
        {
          "type": "object",
          "properties": {
            "schema": {
              "type": "string"
            },
            "value": true,
            "provenance": {
              "$ref": "#/$defs/ManagedRuntimeContextProvenance"
            },
            "kind": {
              "type": "string",
              "const": "workflow_context"
            }
          },
          "required": [
            "kind",
            "schema",
            "value",
            "provenance"
          ]
        },
        {
          "type": "object",
          "properties": {
            "schema": {
              "type": "string"
            },
            "value": true,
            "provenance": {
              "$ref": "#/$defs/ManagedRuntimeContextProvenance"
            },
            "kind": {
              "type": "string",
              "const": "constraint_set"
            }
          },
          "required": [
            "kind",
            "schema",
            "value",
            "provenance"
          ]
        }
      ]
    },
    "ManagedRuntimeContextProvenance": {
      "type": "object",
      "properties": {
        "authority": {
          "$ref": "#/$defs/ManagedRuntimeContextAuthority"
        },
        "source": {
          "type": "string"
        },
        "revision": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        }
      },
      "required": [
        "authority",
        "source",
        "revision",
        "digest"
      ]
    },
    "ManagedRuntimeContextAuthority": {
      "type": "string",
      "enum": [
        "agent_history",
        "agent_snapshot",
        "workflow",
        "constraint"
      ]
    },
    "ManagedRuntimeContentBlock": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "text": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "text"
            }
          },
          "required": [
            "kind",
            "text"
          ]
        },
        {
          "type": "object",
          "properties": {
            "media_type": {
              "type": "string"
            },
            "source": {
              "type": "string"
            },
            "digest": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "image"
            }
          },
          "required": [
            "kind",
            "media_type",
            "source",
            "digest"
          ]
        },
        {
          "type": "object",
          "properties": {
            "uri": {
              "type": "string"
            },
            "media_type": {
              "type": [
                "string",
                "null"
              ]
            },
            "digest": {
              "type": [
                "string",
                "null"
              ]
            },
            "kind": {
              "type": "string",
              "const": "resource"
            }
          },
          "required": [
            "kind",
            "uri"
          ]
        },
        {
          "type": "object",
          "properties": {
            "schema": {
              "type": "string"
            },
            "value": true,
            "kind": {
              "type": "string",
              "const": "structured"
            }
          },
          "required": [
            "kind",
            "schema",
            "value"
          ]
        }
      ]
    },
    "ManagedRuntimeInteractionResponse": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "approved"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "reason": {
              "type": [
                "string",
                "null"
              ]
            },
            "kind": {
              "type": "string",
              "const": "denied"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "content": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/ManagedRuntimeContentBlock"
              }
            },
            "kind": {
              "type": "string",
              "const": "user_input"
            }
          },
          "required": [
            "kind",
            "content"
          ]
        },
        {
          "type": "object",
          "properties": {
            "schema": {
              "type": "string"
            },
            "value": true,
            "kind": {
              "type": "string",
              "const": "structured"
            }
          },
          "required": [
            "kind",
            "schema",
            "value"
          ]
        }
      ]
    },
    "ManagedRuntimeOperationReceipt": {
      "type": "object",
      "properties": {
        "operation_id": {
          "type": "string"
        },
        "thread_id": {
          "type": "string"
        },
        "accepted_revision": {
          "$ref": "#/$defs/RuntimeProjectionRevision"
        },
        "status": {
          "$ref": "#/$defs/ManagedRuntimeOperationStatus"
        },
        "evidence": {
          "anyOf": [
            {
              "$ref": "#/$defs/ManagedRuntimeOperationEvidence"
            },
            {
              "type": "null"
            }
          ]
        },
        "duplicate": {
          "type": "boolean"
        }
      },
      "required": [
        "operation_id",
        "thread_id",
        "accepted_revision",
        "status",
        "duplicate"
      ]
    },
    "ManagedRuntimeOperationStatus": {
      "type": "string",
      "enum": [
        "accepted",
        "running",
        "succeeded",
        "failed",
        "interrupted",
        "lost"
      ]
    },
    "ManagedRuntimeOperationEvidence": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "binding": {
              "$ref": "#/$defs/ManagedRuntimeSourceBindingEvidence"
            },
            "initial_context": {
              "anyOf": [
                {
                  "$ref": "#/$defs/ManagedRuntimeAppliedInitialContextEvidence"
                },
                {
                  "type": "null"
                }
              ]
            },
            "kind": {
              "type": "string",
              "const": "create"
            }
          },
          "required": [
            "kind",
            "binding"
          ]
        },
        {
          "type": "object",
          "properties": {
            "binding": {
              "$ref": "#/$defs/ManagedRuntimeSourceBindingEvidence"
            },
            "kind": {
              "type": "string",
              "const": "resume"
            }
          },
          "required": [
            "kind",
            "binding"
          ]
        },
        {
          "type": "object",
          "properties": {
            "parent_binding": {
              "$ref": "#/$defs/ManagedRuntimeSourceBindingEvidence"
            },
            "progress": {
              "$ref": "#/$defs/ManagedRuntimeForkProgressEvidence"
            },
            "kind": {
              "type": "string",
              "const": "fork"
            }
          },
          "required": [
            "kind",
            "parent_binding",
            "progress"
          ]
        },
        {
          "type": "object",
          "properties": {
            "binding": {
              "$ref": "#/$defs/ManagedRuntimeSourceBindingEvidence"
            },
            "kind": {
              "type": "string",
              "const": "activate"
            }
          },
          "required": [
            "kind",
            "binding"
          ]
        }
      ]
    },
    "ManagedRuntimeSourceBindingEvidence": {
      "type": "object",
      "properties": {
        "source_ref": {
          "type": "string"
        },
        "committed_at_revision": {
          "$ref": "#/$defs/RuntimeProjectionRevision"
        },
        "applied_surface_revision": {
          "$ref": "#/$defs/SurfaceRevision"
        },
        "activated_at_revision": {
          "anyOf": [
            {
              "$ref": "#/$defs/RuntimeProjectionRevision"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "source_ref",
        "committed_at_revision",
        "applied_surface_revision"
      ]
    },
    "SurfaceRevision": {
      "$ref": "#/$defs/RuntimeU64"
    },
    "ManagedRuntimeAppliedInitialContextEvidence": {
      "type": "object",
      "properties": {
        "package_id": {
          "type": "string"
        },
        "package_digest": {
          "type": "string"
        },
        "contributions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ManagedRuntimeInitialContextContributionEvidence"
          }
        }
      },
      "required": [
        "package_id",
        "package_digest",
        "contributions"
      ]
    },
    "ManagedRuntimeInitialContextContributionEvidence": {
      "type": "object",
      "properties": {
        "contribution_id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ManagedRuntimeInitialContextContributionKind"
        },
        "contribution_digest": {
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/ManagedRuntimeAppliedContextProvenance"
        },
        "fidelity": {
          "$ref": "#/$defs/ManagedRuntimeInitialContextAppliedFidelity"
        }
      },
      "required": [
        "contribution_id",
        "kind",
        "contribution_digest",
        "provenance",
        "fidelity"
      ]
    },
    "ManagedRuntimeInitialContextContributionKind": {
      "type": "string",
      "enum": [
        "compact_summary",
        "workflow_context",
        "constraint_set"
      ]
    },
    "ManagedRuntimeAppliedContextProvenance": {
      "type": "object",
      "properties": {
        "authority": {
          "$ref": "#/$defs/ManagedRuntimeContextAuthority"
        },
        "source": {
          "type": "string"
        },
        "revision": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        }
      },
      "required": [
        "authority",
        "source",
        "revision",
        "digest"
      ]
    },
    "ManagedRuntimeInitialContextAppliedFidelity": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "typed_native": {
              "type": "object",
              "properties": {
                "applied_digest": {
                  "type": "string"
                }
              },
              "required": [
                "applied_digest"
              ]
            }
          },
          "required": [
            "typed_native"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "canonical_rendered": {
              "type": "object",
              "properties": {
                "renderer_version": {
                  "type": "string"
                },
                "rendered_digest": {
                  "type": "string"
                }
              },
              "required": [
                "renderer_version",
                "rendered_digest"
              ]
            }
          },
          "required": [
            "canonical_rendered"
          ],
          "additionalProperties": false
        }
      ]
    },
    "ManagedRuntimeForkProgressEvidence": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "child_thread_id": {
              "type": "string"
            },
            "child_source_ref": {
              "type": "string"
            },
            "cutoff": {
              "$ref": "#/$defs/ManagedRuntimeForkCutoff"
            },
            "child_history_digest": {
              "type": [
                "string",
                "null"
              ]
            },
            "status": {
              "type": "string",
              "const": "child_known"
            }
          },
          "required": [
            "status",
            "child_thread_id",
            "child_source_ref",
            "cutoff"
          ]
        },
        {
          "type": "object",
          "properties": {
            "child_thread_id": {
              "type": "string"
            },
            "child_binding": {
              "$ref": "#/$defs/ManagedRuntimeSourceBindingEvidence"
            },
            "cutoff": {
              "$ref": "#/$defs/ManagedRuntimeForkCutoff"
            },
            "child_history_digest": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "const": "provisioned"
            }
          },
          "required": [
            "status",
            "child_thread_id",
            "child_binding",
            "cutoff",
            "child_history_digest"
          ]
        }
      ]
    },
    "ManagedRuntimeForkCutoff": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "head"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "turn_id": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "completed_turn"
            }
          },
          "required": [
            "kind",
            "turn_id"
          ]
        }
      ]
    },
    "ManagedRuntimeReadRequest": {
      "type": "object",
      "properties": {
        "thread_id": {
          "type": "string"
        }
      },
      "required": [
        "thread_id"
      ]
    },
    "ManagedRuntimeChangesRequest": {
      "type": "object",
      "properties": {
        "thread_id": {
          "type": "string"
        },
        "after": {
          "anyOf": [
            {
              "$ref": "#/$defs/RuntimeChangeSequence"
            },
            {
              "type": "null"
            }
          ]
        },
        "limit": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "thread_id",
        "limit"
      ]
    },
    "RuntimeChangeSequence": {
      "$ref": "#/$defs/RuntimeU64"
    },
    "ManagedRuntimeGatewayError": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "actual": {
              "$ref": "#/$defs/RuntimeProjectionRevision"
            },
            "kind": {
              "type": "string",
              "const": "conflict"
            }
          },
          "required": [
            "kind",
            "actual"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "not_found"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "reason": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "unavailable"
            }
          },
          "required": [
            "kind",
            "reason"
          ]
        },
        {
          "type": "object",
          "properties": {
            "reason": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "invalid"
            }
          },
          "required": [
            "kind",
            "reason"
          ]
        },
        {
          "type": "object",
          "properties": {
            "reason": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "persistence"
            }
          },
          "required": [
            "kind",
            "reason"
          ]
        }
      ]
    },
    "ManagedRuntimeSnapshot": {
      "type": "object",
      "properties": {
        "thread_id": {
          "type": "string"
        },
        "revision": {
          "$ref": "#/$defs/RuntimeProjectionRevision"
        },
        "latest_change_sequence": {
          "$ref": "#/$defs/RuntimeChangeSequence"
        },
        "captured_at_ms": {
          "$ref": "#/$defs/RuntimeU64"
        },
        "lifecycle": {
          "$ref": "#/$defs/ManagedRuntimeLifecycleStatus"
        },
        "active_turn_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "turns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ManagedRuntimeTurn"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ManagedRuntimeItem"
          }
        },
        "interactions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ManagedRuntimeInteraction"
          }
        },
        "thread_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "thread_name_source": {
          "anyOf": [
            {
              "$ref": "#/$defs/ManagedRuntimeThreadNameSource"
            },
            {
              "type": "null"
            }
          ]
        },
        "operations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ManagedRuntimeOperation"
          }
        },
        "source_binding": {
          "anyOf": [
            {
              "$ref": "#/$defs/ManagedRuntimeSourceBindingEvidence"
            },
            {
              "type": "null"
            }
          ]
        },
        "authority": {
